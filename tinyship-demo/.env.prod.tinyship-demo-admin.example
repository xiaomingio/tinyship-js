# File purpose: Env template for the admin frontend service. Keep names and comments only, never real secrets.

# Admin frontend: HTTP listen port.
PORT=

# Admin frontend: Page title shown by the frontend.
FRONTEND_TITLE=

# Admin frontend: Runtime label displayed on the page.
FRONTEND_ENV_LABEL=

# Admin frontend: Backend API base URL.
API_BASE_URL=

# Admin frontend: Demo-only audit mode flag.
ADMIN_AUDIT_MODE=
