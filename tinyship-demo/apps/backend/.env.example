# File purpose: Env template for the backend API service. Keep names and comments only, never real secrets.

# Backend API: HTTP listen port.
PORT=

# Backend API: Runtime label returned by /api/env.
BACKEND_ENV_LABEL=

# Backend API: Demo deployment region returned by /api/env.
BACKEND_REGION=

# Backend API: Demo release version returned by /api/env.
BACKEND_RELEASE=
