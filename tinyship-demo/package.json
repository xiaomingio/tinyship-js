{
  "name": "tinyship-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Demo project that uses TinyShip from npm packages.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start:user": "node --env-file=apps/user/.env.production apps/user/dist/user.js",
    "start:admin": "node --env-file=apps/admin/.env.production apps/admin/dist/admin.js",
    "start:backend": "node --env-file=apps/backend/.env.production apps/backend/dist/api.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "tinyship:local:on": "node scripts/tinyship-local.mjs on",
    "tinyship:local:off": "node scripts/tinyship-local.mjs off",
    "deploy": "tinyship deploy",
    "deploy:validate": "tinyship validate",
    "deploy:preflight": "tinyship preflight",
    "deploy:dry-run": "tinyship dry-run all"
  },
  "dependencies": {
    "pm2": "^7.0.1"
  },
  "devDependencies": {
    "@xiaomingio/tinyship": "^0.1.2",
    "@types/node": "^25.8.0",
    "esbuild": "^0.27.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
