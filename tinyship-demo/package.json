{
  "name": "tinyship-demo",
  "version": "0.1.0",
  "private": true,
  "description": "Demo project that uses TinyShip from npm packages.",
  "type": "module",
  "scripts": {
    "build": "node scripts/build.mjs",
    "start:user": "node dist/frontend/user.js",
    "start:admin": "node dist/frontend/admin.js",
    "start:backend": "node dist/backend/api.js",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "deploy:validate": "tinyship validate",
    "deploy:preflight": "tinyship preflight",
    "deploy:dry-run": "tinyship dry-run all",
    "deploy:all": "tinyship deploy all",
    "deploy:frontend": "tinyship deploy frontend",
    "deploy:backend": "tinyship deploy backend"
  },
  "dependencies": {
    "@xiaomingio/tinyship-env": "^0.1.0",
    "pm2": "^7.0.1"
  },
  "devDependencies": {
    "@xiaomingio/tinyship": "^0.1.0",
    "@types/node": "^25.8.0",
    "esbuild": "^0.27.1",
    "tsx": "^4.22.1",
    "typescript": "^6.0.3"
  }
}
